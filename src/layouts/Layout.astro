---
import siteData from '../content/site.json';
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {siteData.titleSuffix}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #faf9f6;
        --bg-soft: #f0ede6;
        --bg-dark: #1a1e23;
        --bg-card: #ffffff;
        --text: #2d2d2d;
        --text-muted: #6b6b6b;
        --text-light: #e8e6e0;
        --accent: #b58863;
        --accent-dark: #8f6a4a;
        --border: #e0ddd5;
        --shadow: 0 2px 12px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 24px rgba(0,0,0,0.12);
        --font-serif: 'Playfair Display', Georgia, serif;
        --font-sans: 'Inter', system-ui, sans-serif;
        --max-width: 1080px;
      }

      html {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      h1, h2, h3 {
        font-family: var(--font-serif);
        line-height: 1.2;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ── Navbar ── */
      nav {
        background: var(--bg);
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid var(--border);
      }

      .nav-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 68px;
      }

      .nav-logo {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0.01em;
      }

      .nav-logo em {
        font-style: normal;
        color: var(--accent);
      }

      .nav-links {
        display: flex;
        gap: 4px;
        list-style: none;
      }

      .nav-links a {
        color: var(--text-muted);
        font-size: 0.88rem;
        font-weight: 500;
        padding: 8px 14px;
        border-radius: 4px;
        transition: color 0.18s;
        letter-spacing: 0.01em;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .nav-links a.active {
        color: var(--text);
        position: relative;
      }

      .nav-links a.active::after {
        content: "";
        position: absolute;
        left: 14px;
        right: 14px;
        bottom: 2px;
        height: 1px;
        background: var(--accent);
      }

      /* ── Footer ── */
      footer {
        background: var(--bg-dark);
        color: #8a857a;
        padding: 32px 24px 24px;
      }

      .footer-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        font-size: 0.88rem;
        text-align: center;
      }

      .footer-brand {
        margin-bottom: 14px;
      }

      .footer-brand strong {
        display: block;
        color: var(--text-light);
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: 1.05rem;
        letter-spacing: 0.02em;
      }

      .footer-columns {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 14px 0;
        border-top: 1px solid rgba(255,255,255,0.08);
        border-bottom: 1px solid rgba(255,255,255,0.08);
        max-width: 720px;
        margin: 0 auto;
      }

      .footer-col {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 6px 18px;
      }

      .footer-col h4 {
        font-family: var(--font-sans);
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        margin: 0;
      }

      .footer-col a {
        color: #8a857a;
        font-size: 0.84rem;
        transition: color 0.18s;
      }

      .footer-col a:hover {
        color: var(--text-light);
      }

      .footer-meta {
        margin-top: 12px;
        font-size: 0.76rem;
        color: #5a5650;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a href="/" class="nav-logo">{siteData.brand}</a>
        <ul class="nav-links">
          {siteData.nav.map((item) => (
            <li><a href={item.href} class={currentPath === item.href ? 'active' : ''}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-brand">
          <strong>{siteData.footer.brand}</strong>
        </div>
        <div class="footer-columns">
          <div class="footer-col">
            <h4>{siteData.footer.follow.label}</h4>
            {siteData.footer.follow.links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener">{link.label}</a>
            ))}
          </div>
          <div class="footer-col">
            <h4>{siteData.footer.support.label}</h4>
            {siteData.footer.support.links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener">{link.label}</a>
            ))}
          </div>
        </div>
        <p class="footer-meta">© {year} {siteData.footer.brand}. {siteData.footer.copyright}</p>
      </div>
    </footer>
  </body>
</html>
