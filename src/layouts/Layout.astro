---
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Chess Coaching</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #faf9f6;
        --bg-soft: #f0ede6;
        --bg-dark: #1a1e23;
        --bg-card: #ffffff;
        --text: #2d2d2d;
        --text-muted: #6b6b6b;
        --text-light: #e8e6e0;
        --accent: #b58863;
        --accent-dark: #8f6a4a;
        --border: #e0ddd5;
        --shadow: 0 2px 12px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 24px rgba(0,0,0,0.12);
        --font-serif: 'Playfair Display', Georgia, serif;
        --font-sans: 'Inter', system-ui, sans-serif;
        --max-width: 1080px;
      }

      html {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      h1, h2, h3 {
        font-family: var(--font-serif);
        line-height: 1.2;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ── Navbar ── */
      nav {
        background: var(--bg);
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid var(--border);
      }

      .nav-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 68px;
      }

      .nav-logo {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0.01em;
      }

      .nav-logo em {
        font-style: normal;
        color: var(--accent);
      }

      .nav-links {
        display: flex;
        gap: 4px;
        list-style: none;
      }

      .nav-links a {
        color: var(--text-muted);
        font-size: 0.88rem;
        font-weight: 500;
        padding: 8px 14px;
        border-radius: 4px;
        transition: color 0.18s;
        letter-spacing: 0.01em;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .nav-links a.active {
        color: var(--text);
        position: relative;
      }

      .nav-links a.active::after {
        content: "";
        position: absolute;
        left: 14px;
        right: 14px;
        bottom: 2px;
        height: 1px;
        background: var(--accent);
      }

      /* ── Footer ── */
      footer {
        background: var(--bg-dark);
        color: #8a857a;
        padding: 56px 24px 40px;
      }

      .footer-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        text-align: center;
        font-size: 0.88rem;
      }

      .footer-inner strong {
        color: var(--text-light);
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: 1.1rem;
        letter-spacing: 0.02em;
      }

      .footer-inner p {
        max-width: 480px;
      }

      .footer-links {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 12px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.06);
        width: 100%;
        max-width: 480px;
      }

      .footer-links a {
        color: #8a857a;
        font-size: 0.82rem;
        transition: color 0.18s;
      }

      .footer-links a:hover {
        color: var(--text-light);
      }

      .footer-meta {
        margin-top: 18px;
        font-size: 0.78rem;
        color: #5a5650;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          Blunder <em>Man</em>
        </a>
        <ul class="nav-links">
          <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
          <li><a href="/lessons" class={currentPath === '/lessons' ? 'active' : ''}>Lessons</a></li>
          <li><a href="/support" class={currentPath === '/support' ? 'active' : ''}>Support</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <strong>Blunder Man</strong>
        <p>Chess coaching with Owen Matthess.</p>
        <div class="footer-links">
          <a href="/lessons">Lessons</a>
          <a href="/support">Support</a>
          <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener">YouTube</a>
          <a href="https://discord.gg/U5sMBn3Wq5" target="_blank" rel="noopener">Discord</a>
          <a href="https://patreon.com/BlunderMan" target="_blank" rel="noopener">Patreon</a>
        </div>
        <p class="footer-meta">© {new Date().getFullYear()} Blunder Man. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
