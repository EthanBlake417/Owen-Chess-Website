---
import Layout from '../layouts/Layout.astro';
import homeData from '../content/home.json';
---

<Layout title="Home">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-photo">
        {homeData.photo
          ? <img src={homeData.photo} alt={homeData.name} />
          : <div class="photo-placeholder">♔</div>
        }
      </div>
      <div class="hero-text">
        <p class="eyebrow">Coaching · YouTube · Community</p>
        <h1>{homeData.name}</h1>
        <p class="hero-bio">{homeData.bio}</p>
        <div class="hero-actions">
          <a href="/lessons" class="btn btn-primary">Book a Lesson</a>
          <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener" class="btn btn-outline">Watch on YouTube <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="grid-section">
    <div class="container">
      <div class="card-grid">

        <a href="/lessons" class="card">
          <span class="card-kicker">01 — Lessons</span>
          <h3>1-on-1 Coaching</h3>
          <p>Personalized sessions tailored to your level and goals. Pick a time that works.</p>
          <span class="card-cta">Book a lesson</span>
        </a>

        <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">02 — YouTube</span>
          <h3>Games &amp; Analysis</h3>
          <p>An intermediate player's honest take on games, openings, and the road to improvement.</p>
          <span class="card-cta">Watch the channel</span>
        </a>

        <a href="https://discord.gg/U5sMBn3Wq5" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">03 — Discord</span>
          <h3>Community</h3>
          <p>Share games, ask questions, and play against other members of the community.</p>
          <span class="card-cta">Join the server</span>
        </a>

        <a href="https://twitch.tv/blundermanyt" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">04 — Twitch</span>
          <h3>Live Streams</h3>
          <p>Catch live gameplay, real-time analysis, and banter with chat.</p>
          <span class="card-cta">Watch live</span>
        </a>

        <a href="https://tiktok.com/@blunderman_yt" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">05 — TikTok</span>
          <h3>Quick Clips</h3>
          <p>Bite-sized chess content, highlights, and quick tips.</p>
          <span class="card-cta">Watch on TikTok</span>
        </a>

        <a href="https://blunder-man.myspreadshop.com" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">06 — Merch</span>
          <h3>Blunder Man Shop</h3>
          <p>Shirts and gear from the official Blunder Man merch store.</p>
          <span class="card-cta">Browse merch</span>
        </a>

        <a href="https://paypal.com/ncp/payment/YM3PF6FPDC26G" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">07 — PayPal</span>
          <h3>One-Time Donation</h3>
          <p>Donate any amount via PayPal. No account required.</p>
          <span class="card-cta">Donate</span>
        </a>

        <a href="https://go.noctie.ai/blunderman" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">08 — Noctie</span>
          <h3>Chess Training AI</h3>
          <p>AI-powered training tool. Try it through this referral link.</p>
          <span class="card-cta">Try Noctie</span>
        </a>

        <a href="https://chess.com/membership?ref_id=324248631" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">09 — Chess.com</span>
          <h3>Membership Referral</h3>
          <p>Sign up for Chess.com through this referral. Costs you nothing extra.</p>
          <span class="card-cta">Sign up</span>
        </a>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 64px 0 64px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 56px;
    align-items: center;
  }

  .hero-photo img {
    width: 240px;
    height: 280px;
    border-radius: 2px;
    object-fit: cover;
    filter: grayscale(0.1) contrast(1.02);
  }

  .photo-placeholder {
    width: 240px;
    height: 280px;
    border-radius: 2px;
    background: rgba(255,255,255,0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    color: var(--text-light);
    opacity: 0.3;
  }

  .eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 18px;
    font-weight: 500;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 4.4vw, 3.2rem);
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    color: var(--text-light);
  }

  .hero-bio {
    font-size: 1.02rem;
    line-height: 1.65;
    color: #a8a298;
    max-width: 540px;
    margin-bottom: 30px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    font-size: 0.92rem;
    transition: all 0.18s ease;
    letter-spacing: 0.01em;
    padding: 12px 24px;
    border-radius: 2px;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }

  .btn-outline {
    background: transparent;
    color: var(--text-light);
    border-color: rgba(232, 230, 224, 0.3);
  }

  .btn-outline:hover {
    border-color: var(--text-light);
    background: rgba(255,255,255,0.04);
  }

  .btn-outline span {
    display: inline-block;
    transition: transform 0.18s ease;
  }

  .btn-outline:hover span {
    transform: translateX(3px);
  }

  /* ── Card Grid ── */
  .grid-section {
    padding: 88px 0;
    background: var(--bg);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    padding: 44px 36px 40px;
    transition: background 0.2s ease;
    min-height: 240px;
    overflow: hidden;
  }

  .card:hover {
    background: var(--bg);
  }

  .card-kicker {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    margin-bottom: 28px;
    font-weight: 500;
  }

  .card h3 {
    font-size: 1.55rem;
    margin-bottom: 12px;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  .card p {
    font-size: 0.96rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 28px;
  }

  .card-cta {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    position: relative;
    display: inline-block;
    align-self: flex-start;
  }

  .card-cta::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1px;
    background: var(--text);
    transform-origin: left;
    transform: scaleX(0.3);
    transition: transform 0.25s ease;
  }

  .card:hover .card-cta::after {
    transform: scaleX(1);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero { padding: 48px 0 48px; }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: left;
    }
    .hero-photo img,
    .photo-placeholder {
      width: 100%;
      max-width: 280px;
      height: auto;
      aspect-ratio: 4 / 5;
    }
    .grid-section { padding: 56px 0; }
    .card-grid { grid-template-columns: 1fr; }
    .card { padding: 36px 28px 32px; min-height: 0; }
  }
</style>
