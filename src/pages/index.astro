---
import Layout from '../layouts/Layout.astro';
import homeData from '../content/home.json';
---

<Layout title="Home">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-photo">
        {homeData.photo
          ? <img src={homeData.photo} alt="Blunder Man" />
          : <div class="photo-placeholder">♔</div>
        }
      </div>
      <div class="hero-text">
        <h1>{homeData.name}</h1>
        <p class="hero-bio">{homeData.bio}</p>
        <div class="hero-actions">
          <a href="/lessons" class="btn btn-primary">Book a Lesson</a>
          <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener" class="btn btn-outline">Watch on YouTube ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="grid-section">
    <div class="container">
      <div class="card-grid">

        <a href="/lessons" class="card card-dark">
          <div class="card-icon">♟</div>
          <h3>1-on-1 Lessons</h3>
          <p>Personalized coaching sessions tailored to your level and goals. Book a time that works for you.</p>
          <span class="card-cta">View Packages →</span>
        </a>

        <a href="/support" class="card card-accent">
          <div class="card-icon">♛</div>
          <h3>Support the Channel</h3>
          <p>Join on Patreon, grab some merch, or make a one-time donation. Every bit helps.</p>
          <span class="card-cta">Support →</span>
        </a>

        <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener" class="card">
          <div class="card-icon">▶</div>
          <h3>YouTube</h3>
          <p>Watch games, analysis, and tips from an advanced/intermediate player's honest perspective.</p>
          <span class="card-cta">Watch Now →</span>
        </a>

        <a href="https://discord.gg/U5sMBn3Wq5" target="_blank" rel="noopener" class="card">
          <div class="card-icon">💬</div>
          <h3>Discord Community</h3>
          <p>Join the community, share your games, ask questions, and play each other.</p>
          <span class="card-cta">Join Discord →</span>
        </a>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 72px 0;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 56px;
    align-items: center;
  }

  .hero-photo img {
    width: 280px;
    height: 280px;
    border-radius: 12px;
    object-fit: cover;
    border: 3px solid var(--accent);
  }

  .photo-placeholder {
    width: 280px;
    height: 280px;
    border-radius: 12px;
    background: #2a2e35;
    border: 3px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    opacity: 0.4;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    margin-bottom: 20px;
  }

  .hero-bio {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #b0ada6;
    max-width: 540px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.18s;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    transform: translateY(-1px);
  }

  .btn-outline {
    background: transparent;
    color: var(--text-light);
    border: 2px solid rgba(255,255,255,0.18);
  }

  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Card Grid ── */
  .grid-section {
    padding: 72px 0;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 36px 32px;
    transition: box-shadow 0.2s, transform 0.2s;
    box-shadow: var(--shadow);
  }

  .card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .card-dark {
    background: var(--bg-dark);
    border-color: #2a2e35;
    color: var(--text-light);
  }

  .card-dark h3 { color: var(--text-light); }
  .card-dark p  { color: #9095a0; }
  .card-dark .card-cta { color: var(--accent); }

  .card-accent {
    background: var(--accent);
    border-color: var(--accent-dark);
    color: #fff;
  }

  .card-accent h3 { color: #fff; }
  .card-accent p  { color: rgba(255,255,255,0.82); }
  .card-accent .card-cta { color: #fff; font-weight: 700; }

  .card-icon {
    font-size: 1.8rem;
    margin-bottom: 16px;
  }

  .card h3 {
    font-size: 1.25rem;
    margin-bottom: 10px;
    color: var(--text);
  }

  .card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 20px;
  }

  .card-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-photo { margin: 0 auto; }
    .hero-actions { justify-content: center; }
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
