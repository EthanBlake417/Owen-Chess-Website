---
import Layout from '../layouts/Layout.astro';
import homeData from '../content/home.json';
---

<Layout title="Home">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-photo">
        {homeData.photo
          ? <img src={homeData.photo} alt={homeData.name} />
          : <div class="photo-placeholder">♔</div>
        }
      </div>
      <div class="hero-text">
        <p class="eyebrow">Coaching · YouTube · Community</p>
        <h1>{homeData.name}</h1>
        <p class="hero-bio">{homeData.bio}</p>
        <div class="hero-actions">
          <a href="/lessons" class="btn btn-primary">Book a Lesson</a>
          <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener" class="btn btn-outline">Watch on YouTube <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="grid-section">
    <div class="container">
      <div class="card-grid">

        <a href="/lessons" class="card">
          <span class="card-kicker">01 — Lessons</span>
          <h3>1-on-1 Coaching</h3>
          <p>Personalized sessions tailored to your level and goals. Pick a time that works.</p>
          <span class="card-cta">Book a lesson</span>
        </a>

        <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">02 — YouTube</span>
          <h3>Games &amp; Analysis</h3>
          <p>An intermediate player's honest take on games, openings, and the road to improvement.</p>
          <span class="card-cta">Watch the channel</span>
        </a>

        <a href="https://discord.gg/U5sMBn3Wq5" target="_blank" rel="noopener" class="card">
          <span class="card-kicker">03 — Community</span>
          <h3>Discord</h3>
          <p>Share games, ask questions, and play against other members of the community.</p>
          <span class="card-cta">Join the server</span>
        </a>

        <a href="/support" class="card card-accent">
          <span class="card-kicker">04 — Support</span>
          <h3>Back the Channel</h3>
          <p>Patreon, merch, or a one-time donation. Every bit helps keep new content coming.</p>
          <span class="card-cta">See the options</span>
          <span class="card-stripe" aria-hidden="true"></span>
        </a>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 64px 0 64px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 56px;
    align-items: center;
  }

  .hero-photo img {
    width: 240px;
    height: 280px;
    border-radius: 2px;
    object-fit: cover;
    filter: grayscale(0.1) contrast(1.02);
  }

  .photo-placeholder {
    width: 240px;
    height: 280px;
    border-radius: 2px;
    background: rgba(255,255,255,0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    color: var(--text-light);
    opacity: 0.3;
  }

  .eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 18px;
    font-weight: 500;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 4.4vw, 3.2rem);
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    color: var(--text-light);
  }

  .hero-bio {
    font-size: 1.02rem;
    line-height: 1.65;
    color: #a8a298;
    max-width: 540px;
    margin-bottom: 30px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    font-size: 0.92rem;
    transition: all 0.18s ease;
    letter-spacing: 0.01em;
    padding: 12px 24px;
    border-radius: 2px;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }

  .btn-outline {
    background: transparent;
    color: var(--text-light);
    border-color: rgba(232, 230, 224, 0.3);
  }

  .btn-outline:hover {
    border-color: var(--text-light);
    background: rgba(255,255,255,0.04);
  }

  .btn-outline span {
    display: inline-block;
    transition: transform 0.18s ease;
  }

  .btn-outline:hover span {
    transform: translateX(3px);
  }

  /* ── Card Grid ── */
  .grid-section {
    padding: 88px 0;
    background: var(--bg);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    padding: 44px 36px 40px;
    transition: background 0.2s ease;
    min-height: 240px;
    overflow: hidden;
  }

  .card:hover {
    background: var(--bg);
  }

  .card-accent .card-stripe {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
    background: var(--accent);
  }

  .card-accent {
    padding-left: 44px;
  }

  .card-kicker {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    margin-bottom: 28px;
    font-weight: 500;
  }

  .card h3 {
    font-size: 1.55rem;
    margin-bottom: 12px;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  .card p {
    font-size: 0.96rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 28px;
  }

  .card-cta {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    position: relative;
    display: inline-block;
    align-self: flex-start;
  }

  .card-cta::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1px;
    background: var(--text);
    transform-origin: left;
    transform: scaleX(0.3);
    transition: transform 0.25s ease;
  }

  .card:hover .card-cta::after {
    transform: scaleX(1);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero { padding: 48px 0 48px; }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: left;
    }
    .hero-photo img,
    .photo-placeholder {
      width: 100%;
      max-width: 280px;
      height: auto;
      aspect-ratio: 4 / 5;
    }
    .grid-section { padding: 56px 0; }
    .card-grid { grid-template-columns: 1fr; }
    .card { padding: 36px 28px 32px; min-height: 0; }
  }
</style>
