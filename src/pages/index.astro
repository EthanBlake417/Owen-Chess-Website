---
import Layout from '../layouts/Layout.astro';
import homeData from '../content/home.json';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="hero-eyebrow">Chess Coaching</p>
          <h1>{homeData.name}</h1>
          <p class="hero-tagline">{homeData.tagline}</p>
          <p class="hero-bio">{homeData.bio}</p>
          <div class="hero-actions">
            <a href="/lessons" class="btn btn-primary">Book a Lesson</a>
            <a href="/courses" class="btn btn-secondary">View Courses</a>
          </div>
        </div>
        <div class="hero-photo">
          {homeData.photo
            ? <img src={homeData.photo} alt={homeData.name} />
            : <div class="photo-placeholder">♔</div>
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Why coaching section -->
  <section class="why">
    <div class="container">
      <h2>Why 1-on-1 Coaching?</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">♟</div>
          <h3>Personalized Feedback</h3>
          <p>Your games analyzed, your weaknesses targeted. No generic advice — training built around your specific play style.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">♜</div>
          <h3>Structured Improvement</h3>
          <p>A clear roadmap from where you are to where you want to be, with measurable milestones along the way.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">♛</div>
          <h3>Learn Faster</h3>
          <p>Direct coaching compresses months of self-study into weeks. Skip the wrong turns and focus on what actually matters.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <h2>Ready to level up your game?</h2>
      <p>Book your first session today — no long-term commitment required.</p>
      <a href="/lessons" class="btn btn-primary btn-large">See Lesson Packages</a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 80px 0;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 60px;
    align-items: center;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .hero-tagline {
    font-size: 1.1rem;
    color: #a0a0a0;
    margin-bottom: 24px;
  }

  .hero-bio {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #c8c4bc;
    max-width: 560px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-photo img {
    width: 260px;
    height: 260px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--accent);
  }

  .photo-placeholder {
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: #2a2e35;
    border: 4px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    opacity: 0.5;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-light);
    border: 2px solid rgba(255,255,255,0.2);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-large {
    padding: 16px 40px;
    font-size: 1rem;
  }

  /* ── Why section ── */
  .why {
    padding: 80px 0;
  }

  .why h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 48px;
    color: var(--text);
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .why-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px 28px;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .why-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .why-icon {
    font-size: 2rem;
    margin-bottom: 16px;
    opacity: 0.8;
  }

  .why-card h3 {
    font-size: 1.1rem;
    margin-bottom: 10px;
    color: var(--text);
  }

  .why-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── CTA Banner ── */
  .cta-banner {
    background: var(--accent);
    padding: 64px 0;
    text-align: center;
  }

  .cta-banner h2 {
    font-size: 2rem;
    color: white;
    margin-bottom: 12px;
  }

  .cta-banner p {
    color: rgba(255,255,255,0.85);
    font-size: 1.05rem;
    margin-bottom: 32px;
  }

  .cta-banner .btn-primary {
    background: white;
    color: var(--accent-dark);
  }

  .cta-banner .btn-primary:hover {
    background: #f5f5f5;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-photo {
      display: none;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
