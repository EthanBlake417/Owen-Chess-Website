---
import Layout from '../layouts/Layout.astro';
import homeData from '../content/home.json';

const socials = [
  { label: 'YouTube',   href: 'https://www.youtube.com/@Blunder_Man',                          icon: '▶' },
  { label: 'Discord',   href: 'https://discord.gg/U5sMBn3Wq5',                                 icon: '💬' },
  { label: 'Instagram', href: 'https://instagram.com/blunderman_yt',                            icon: '📷' },
  { label: 'TikTok',    href: 'https://tiktok.com/@blunderman_yt',                              icon: '🎵' },
  { label: 'Twitch',    href: 'https://twitch.tv/blundermanyt',                                 icon: '🎮' },
  { label: 'Facebook',  href: 'https://facebook.com/profile.php?id=61579270563658',             icon: '👤' },
];

const support = [
  { label: 'Patreon',      href: 'https://patreon.com/BlunderMan',                             desc: 'Support the channel' },
  { label: 'Merch Store',  href: 'https://blunder-man.myspreadshop.com',                       desc: 'Blunder Man gear' },
  { label: 'Donate',       href: 'https://paypal.com/ncp/payment/YM3PF6FPDC26G',              desc: 'via PayPal' },
];

const partners = [
  { label: 'Chess.com',  href: 'https://chess.com/membership?ref_id=324248631', desc: 'Get a Chess.com membership' },
  { label: 'Noctie AI',  href: 'https://go.noctie.ai/blunderman',               desc: 'AI chess training tool' },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="hero-eyebrow">Chess Coaching</p>
          <h1>{homeData.name}</h1>
          <p class="hero-subtitle">{homeData.subtitle}</p>
          <p class="hero-tagline">{homeData.tagline}</p>
          <p class="hero-bio">{homeData.bio}</p>
          <div class="hero-actions">
            <a href="/lessons" class="btn btn-primary">Book a Lesson</a>
            <a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener" class="btn btn-secondary">Watch on YouTube</a>
          </div>
        </div>
        <div class="hero-photo">
          {homeData.photo
            ? <img src={homeData.photo} alt={homeData.name} />
            : <div class="photo-placeholder">♔</div>
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Socials -->
  <section class="socials">
    <div class="container">
      <p class="socials-label">Find me on</p>
      <div class="socials-row">
        {socials.map(s => (
          <a href={s.href} target="_blank" rel="noopener" class="social-chip">
            <span>{s.icon}</span> {s.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why coaching -->
  <section class="why">
    <div class="container">
      <h2>Why 1-on-1 Coaching?</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">♟</div>
          <h3>Personalized Feedback</h3>
          <p>Your games analyzed, your weaknesses targeted. No generic advice — training built around your specific play style.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">♜</div>
          <h3>Stop Blundering</h3>
          <p>Identify the patterns behind your mistakes and build the habits to eliminate them for good.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">♛</div>
          <h3>Learn Faster</h3>
          <p>Direct coaching compresses months of self-study into weeks. Skip the wrong turns and focus on what actually matters.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Support & Partners -->
  <section class="support-section">
    <div class="container">
      <div class="support-grid">
        <div class="support-col">
          <h3>Support the Channel</h3>
          <div class="link-list">
            {support.map(s => (
              <a href={s.href} target="_blank" rel="noopener" class="support-link">
                <strong>{s.label}</strong>
                <span>{s.desc}</span>
              </a>
            ))}
          </div>
        </div>
        <div class="support-col">
          <h3>Partners & Tools</h3>
          <div class="link-list">
            {partners.map(p => (
              <a href={p.href} target="_blank" rel="noopener" class="support-link">
                <strong>{p.label}</strong>
                <span>{p.desc}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <h2>Ready to stop blundering?</h2>
      <p>Book your first coaching session — no long-term commitment required.</p>
      <a href="/lessons" class="btn btn-primary btn-large">See Lesson Packages</a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 80px 0;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 60px;
    align-items: center;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    margin-bottom: 4px;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: #888;
    margin-bottom: 10px;
    font-style: italic;
  }

  .hero-tagline {
    font-size: 1.1rem;
    color: #a0a0a0;
    margin-bottom: 24px;
  }

  .hero-bio {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #c8c4bc;
    max-width: 560px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-photo img {
    width: 260px;
    height: 260px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--accent);
  }

  .photo-placeholder {
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: #2a2e35;
    border: 4px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 6rem;
    opacity: 0.5;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-light);
    border: 2px solid rgba(255,255,255,0.2);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-large {
    padding: 16px 40px;
    font-size: 1rem;
  }

  /* ── Socials ── */
  .socials {
    background: #111418;
    padding: 28px 0;
    border-bottom: 1px solid #2a2e35;
  }

  .socials-label {
    text-align: center;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 14px;
  }

  .socials-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .social-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #1e2228;
    border: 1px solid #2a2e35;
    color: #a0a0a0;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .social-chip:hover {
    background: #2a2e35;
    color: var(--text-light);
    border-color: var(--accent);
  }

  /* ── Why section ── */
  .why {
    padding: 80px 0;
  }

  .why h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 48px;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .why-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px 28px;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .why-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .why-icon {
    font-size: 2rem;
    margin-bottom: 16px;
    opacity: 0.8;
  }

  .why-card h3 {
    font-size: 1.1rem;
    margin-bottom: 10px;
  }

  .why-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── Support & Partners ── */
  .support-section {
    background: #f0ede6;
    padding: 64px 0;
  }

  .support-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 800px;
    margin: 0 auto;
  }

  .support-col h3 {
    font-size: 1.1rem;
    margin-bottom: 20px;
    color: var(--text);
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .support-link {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .support-link:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }

  .support-link strong {
    font-size: 0.95rem;
    color: var(--text);
  }

  .support-link span {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* ── CTA Banner ── */
  .cta-banner {
    background: var(--accent);
    padding: 64px 0;
    text-align: center;
  }

  .cta-banner h2 {
    font-size: 2rem;
    color: white;
    margin-bottom: 12px;
  }

  .cta-banner p {
    color: rgba(255,255,255,0.85);
    font-size: 1.05rem;
    margin-bottom: 32px;
  }

  .cta-banner .btn-primary {
    background: white;
    color: var(--accent-dark);
  }

  .cta-banner .btn-primary:hover {
    background: #f5f5f5;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-photo { display: none; }
    .why-grid { grid-template-columns: 1fr; }
    .support-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
