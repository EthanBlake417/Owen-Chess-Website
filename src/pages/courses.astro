---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Courses">
  <section class="page-header">
    <div class="container">
      <h1>Courses</h1>
      <p>Structured self-paced programs to build your chess foundation.</p>
    </div>
  </section>

  <section class="courses-content">
    <div class="container">
      <div class="coming-soon">
        <div class="cs-icon">♞</div>
        <h2>Courses Coming Soon</h2>
        <p>
          Self-paced video courses are in development. In the meantime,
          <a href="/lessons">book a 1-on-1 lesson</a> to get personalized training right away.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 64px 0;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: #a0a0a0;
    max-width: 500px;
    margin: 0 auto;
  }

  .courses-content {
    padding: 100px 0;
  }

  .coming-soon {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .cs-icon {
    font-size: 4rem;
    margin-bottom: 20px;
    opacity: 0.4;
  }

  .coming-soon h2 {
    font-size: 1.8rem;
    margin-bottom: 16px;
    color: var(--text);
  }

  .coming-soon p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .coming-soon a {
    color: var(--accent);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
