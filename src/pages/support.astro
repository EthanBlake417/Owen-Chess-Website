---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Support">

  <section class="page-header">
    <div class="container">
      <p class="eyebrow">Support</p>
      <h1>Back the channel.</h1>
      <p class="lede">Every bit of support keeps the videos, streams, and lessons going. Thank you.</p>
    </div>
  </section>

  <!-- Featured: Patreon -->
  <section class="patreon-section">
    <div class="container">
      <div class="patreon-card">
        <div class="patreon-text">
          <p class="label">Members</p>
          <h2>Become a Patron</h2>
          <p>Exclusive content, early access to videos, and direct contact with Owen. Pick whichever tier fits.</p>
          <a href="https://patreon.com/BlunderMan" target="_blank" rel="noopener" class="btn-patreon">
            Join on Patreon <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="patreon-aside">
          <span class="patreon-mark">P</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Support Grid -->
  <section class="support-grid-section">
    <div class="container">
      <div class="section-head">
        <h2>Other ways to help</h2>
        <p>No-cost and one-time options if Patreon isn't your thing.</p>
      </div>
      <div class="support-grid">

        <a href="https://paypal.com/ncp/payment/YM3PF6FPDC26G" target="_blank" rel="noopener" class="s-card">
          <span class="s-num">01</span>
          <h3>PayPal Donation</h3>
          <p>One-time donation, any amount. No account required.</p>
          <span class="s-cta">Donate</span>
        </a>

        <a href="https://blunder-man.myspreadshop.com" target="_blank" rel="noopener" class="s-card">
          <span class="s-num">02</span>
          <h3>Merch Store</h3>
          <p>Shirts and gear from the Blunder Man shop.</p>
          <span class="s-cta">Browse</span>
        </a>

        <a href="https://chess.com/membership?ref_id=324248631" target="_blank" rel="noopener" class="s-card">
          <span class="s-num">03</span>
          <h3>Chess.com Membership</h3>
          <p>Sign up through this referral link — no extra cost to you.</p>
          <span class="s-cta">Sign up</span>
        </a>

        <a href="https://go.noctie.ai/blunderman" target="_blank" rel="noopener" class="s-card">
          <span class="s-num">04</span>
          <h3>Noctie AI</h3>
          <p>AI-powered chess training. Try it with this referral.</p>
          <span class="s-cta">Try Noctie</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Social Links -->
  <section class="socials-section">
    <div class="container">
      <div class="section-head">
        <h2>Follow along</h2>
        <p>Find me wherever you spend your time.</p>
      </div>
      <ul class="socials-list">
        <li><a href="https://www.youtube.com/@Blunder_Man" target="_blank" rel="noopener"><span class="s-emoji" aria-hidden="true">📺</span><span class="s-label">YouTube</span><span class="s-arrow" aria-hidden="true">↗</span></a></li>
        <li><a href="https://discord.gg/U5sMBn3Wq5" target="_blank" rel="noopener"><span class="s-emoji" aria-hidden="true">💬</span><span class="s-label">Discord</span><span class="s-arrow" aria-hidden="true">↗</span></a></li>
        <li><a href="https://twitch.tv/blundermanyt" target="_blank" rel="noopener"><span class="s-emoji" aria-hidden="true">🎮</span><span class="s-label">Twitch</span><span class="s-arrow" aria-hidden="true">↗</span></a></li>
        <li><a href="https://instagram.com/blunderman_yt" target="_blank" rel="noopener"><span class="s-emoji" aria-hidden="true">📷</span><span class="s-label">Instagram</span><span class="s-arrow" aria-hidden="true">↗</span></a></li>
        <li><a href="https://tiktok.com/@blunderman_yt" target="_blank" rel="noopener"><span class="s-emoji" aria-hidden="true">🎵</span><span class="s-label">TikTok</span><span class="s-arrow" aria-hidden="true">↗</span></a></li>
        <li><a href="https://facebook.com/profile.php?id=61579270563658" target="_blank" rel="noopener"><span class="s-emoji" aria-hidden="true">👤</span><span class="s-label">Facebook</span><span class="s-arrow" aria-hidden="true">↗</span></a></li>
      </ul>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 96px 0 80px;
  }

  .page-header h1 { color: var(--text-light); }
  .page-header .lede { color: #a8a298; }

  .eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .page-header h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    margin-bottom: 18px;
    letter-spacing: -0.01em;
  }

  .page-header .lede {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 560px;
    line-height: 1.65;
  }

  .section-head {
    margin-bottom: 44px;
    max-width: 560px;
  }

  .section-head h2 {
    font-size: 1.9rem;
    margin-bottom: 10px;
    letter-spacing: -0.005em;
  }

  .section-head p {
    color: var(--text-muted);
    font-size: 0.96rem;
  }

  /* ── Patreon ── */
  .patreon-section {
    padding: 80px 0;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }

  .patreon-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 56px 56px 56px 60px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 48px;
    color: var(--text);
    overflow: hidden;
  }

  .patreon-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
    background: var(--accent);
  }

  .patreon-text .label {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .patreon-text h2 {
    font-size: 2.4rem;
    margin-bottom: 16px;
    color: var(--text);
    font-family: var(--font-serif);
    letter-spacing: -0.005em;
  }

  .patreon-text p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 32px;
  }

  .btn-patreon {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    border-bottom: 1px solid var(--text);
    padding: 6px 2px;
    transition: color 0.18s, border-color 0.18s;
  }

  .btn-patreon:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .btn-patreon span {
    transition: transform 0.18s ease;
  }

  .btn-patreon:hover span {
    transform: translateX(3px);
  }

  .patreon-aside {
    width: 160px;
    height: 160px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
  }

  .patreon-mark {
    font-family: var(--font-serif);
    font-size: 7rem;
    line-height: 1;
    color: var(--accent);
  }

  /* ── Support Grid ── */
  .support-grid-section {
    padding: 80px 0;
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .s-card {
    background: var(--bg-card);
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background 0.2s;
  }

  .s-card:hover {
    background: var(--bg);
  }

  .s-num {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .s-card h3 {
    font-size: 1.25rem;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.005em;
  }

  .s-card p {
    font-size: 0.94rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .s-cta {
    margin-top: 16px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    position: relative;
    align-self: flex-start;
  }

  .s-cta::after {
    content: " →";
    transition: margin 0.18s ease;
  }

  .s-card:hover .s-cta::after {
    margin-left: 4px;
  }

  /* ── Socials ── */
  .socials-section {
    padding: 80px 0 64px;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
  }

  .socials-list {
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .socials-list li {
    border-bottom: 1px solid var(--border);
  }

  .socials-list a {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 22px 4px;
    color: var(--text);
    transition: color 0.18s, padding 0.18s;
  }

  .socials-list a:hover {
    color: var(--accent);
    padding-left: 12px;
  }

  .s-emoji {
    font-size: 1.4rem;
    width: 28px;
    text-align: center;
    flex-shrink: 0;
  }

  .s-label {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    flex: 1;
  }

  .s-arrow {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text-muted);
    transition: color 0.18s, transform 0.18s ease;
  }

  .socials-list a:hover .s-arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .patreon-card {
      grid-template-columns: 1fr;
      padding: 44px 32px;
      gap: 32px;
    }
    .patreon-text h2 { font-size: 2rem; }
    .patreon-aside { width: 120px; height: 120px; }
    .patreon-mark { font-size: 5rem; }
    .support-grid { grid-template-columns: 1fr; }
    .socials-list a { font-size: 1.2rem; }
  }
</style>
