---
import Layout from '../layouts/Layout.astro';
import lessonsData from '../content/lessons.json';

const CAL_USERNAME = lessonsData.calUsername;
---

<Layout title="Lessons">

  <!-- Booking -->
  <section class="booking" id="book">
    <div class="container">
      <div class="section-head">
        <h1>{lessonsData.heading}</h1>
      </div>
    </div>
    <div class="container container-wide">
      <div id="cal-inline" class="cal-wrap"></div>
    </div>
  </section>

  <script is:inline define:vars={{ CAL_USERNAME }}>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal; let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {}; cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]);
          } else { p(cal, ar); }
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://cal.com" });

    Cal("inline", {
      elementOrSelector: "#cal-inline",
      calLink: CAL_USERNAME,
      config: { layout: "month_view", theme: "light" }
    });

    Cal("ui", {
      theme: "light",
      hideEventTypeDetails: false,
      layout: "month_view",
      styles: {
        branding: { brandColor: "#b58863" }
      }
    });
  </script>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <div class="section-head">
        <h2>{lessonsData.faq.heading}</h2>
      </div>
      <div class="faq-list">
        {lessonsData.faq.items.map((item) => (
          <div class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-head {
    margin-bottom: 32px;
    max-width: 600px;
  }

  .section-head h1 {
    font-size: clamp(2rem, 4vw, 2.6rem);
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .section-head h2 {
    font-size: 1.9rem;
    margin-bottom: 10px;
    letter-spacing: -0.005em;
  }

  /* ── Booking ── */
  .booking {
    background: var(--bg);
    padding: 56px 0 96px;
  }

  .container-wide {
    max-width: 1180px;
  }

  .cal-wrap {
    width: 100%;
    min-height: 560px;
    background: transparent;
  }

  .cal-wrap :global(iframe) {
    width: 100% !important;
    border: 0;
  }

  /* ── FAQ ── */
  .faq {
    padding: 88px 0;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 760px;
    border-top: 1px solid var(--border);
  }

  .faq-item {
    padding: 26px 4px;
    border-bottom: 1px solid var(--border);
  }

  .faq-item h3 {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }

  .faq-item p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>
