---
import Layout from '../layouts/Layout.astro';
import lessonsData from '../content/lessons.json';

const CAL_USERNAME = lessonsData.calUsername;
---

<Layout title="Lessons">

  <!-- Booking -->
  <section class="booking" id="book">
    <div class="container container-wide">
      <div class="section-head">
        <h1>{lessonsData.heading}</h1>
      </div>

      <div id="cal-inline" class="cal-wrap"></div>

      <div class="payment">
        <div class="payment-head">
          <h2>{lessonsData.payment.heading}</h2>
          <span class="payment-price">{lessonsData.payment.price}</span>
        </div>
        <p class="payment-note">{lessonsData.payment.note}</p>
        <div class="payment-buttons">
          <a
            href={lessonsData.payment.venmo.url}
            target="_blank"
            rel="noopener"
            class="btn-pay btn-pay-primary"
          >
            <span>{lessonsData.payment.venmo.label}</span>
            {lessonsData.payment.venmo.preferredBadge && (
              <span class="preferred-badge">{lessonsData.payment.venmo.preferredBadge}</span>
            )}
          </a>
          <a
            href={lessonsData.payment.paypal.url}
            target="_blank"
            rel="noopener"
            class="btn-pay btn-pay-outline"
          >
            {lessonsData.payment.paypal.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ CAL_USERNAME }}>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal; let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {}; cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]);
          } else { p(cal, ar); }
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://cal.com" });

    Cal("inline", {
      elementOrSelector: "#cal-inline",
      calLink: CAL_USERNAME,
      config: { layout: "month_view", theme: "light" }
    });

    Cal("ui", {
      theme: "light",
      hideEventTypeDetails: false,
      layout: "month_view",
      styles: {
        branding: { brandColor: "#b58863" }
      }
    });
  </script>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <div class="section-head">
        <h2>{lessonsData.faq.heading}</h2>
      </div>
      <div class="faq-list">
        {lessonsData.faq.items.map((item) => (
          <div class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-head {
    margin-bottom: 32px;
    max-width: 600px;
  }

  .booking .section-head {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .section-head h1 {
    font-size: clamp(2rem, 4vw, 2.6rem);
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .section-head h2 {
    font-size: 1.9rem;
    margin-bottom: 10px;
    letter-spacing: -0.005em;
  }

  /* ── Booking ── */
  .booking {
    background: var(--bg);
    padding: 56px 0 96px;
  }

  .container-wide {
    max-width: 1180px;
  }

  /* ── Payment ── */
  .payment {
    border: 1px solid var(--border);
    background: var(--bg-card);
    padding: 28px 32px;
    margin: 12px auto 0;
    max-width: 1040px;
    width: 100%;
    border-radius: 10px;
  }

  .payment-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .payment-head h2 {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .payment-price {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--accent);
    font-weight: 600;
  }

  .payment-note {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 22px;
    max-width: 580px;
  }

  .payment-buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .btn-pay {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 11px 22px;
    border-radius: 2px;
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    border: 1px solid transparent;
    transition: all 0.18s ease;
  }

  .btn-pay-primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .btn-pay-primary:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }

  .btn-pay-outline {
    background: transparent;
    color: var(--text);
    border-color: var(--border);
  }

  .btn-pay-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .preferred-badge {
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 8px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 999px;
    line-height: 1;
    white-space: nowrap;
  }

  .cal-wrap {
    width: 100%;
    max-width: 1040px;
    margin: 0 auto;
    min-height: 560px;
    background: transparent;
  }

  .cal-wrap :global(iframe) {
    width: 100% !important;
    border: 0;
  }

  @media (max-width: 520px) {
    .payment {
      padding: 22px 22px 24px;
    }
    .payment-buttons {
      flex-direction: column;
      align-items: stretch;
    }
    .btn-pay {
      justify-content: center;
    }
  }

  /* ── FAQ ── */
  .faq {
    padding: 88px 0;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 760px;
    border-top: 1px solid var(--border);
  }

  .faq-item {
    padding: 26px 4px;
    border-bottom: 1px solid var(--border);
  }

  .faq-item h3 {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }

  .faq-item p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>
