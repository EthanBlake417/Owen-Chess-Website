---
import Layout from '../layouts/Layout.astro';
import lessonsData from '../content/lessons.json';

const CAL_USERNAME = 'ethan-blake-testing';
---

<Layout title="Lessons">

  <section class="page-header">
    <div class="container">
      <h1>1-on-1 Lessons</h1>
      <p>{lessonsData.intro}</p>
    </div>
  </section>

  <!-- Packages -->
  <section class="packages">
    <div class="container">
      <h2>Choose a Package</h2>
      <div class="packages-grid">
        {lessonsData.packages.map((pkg, i) => (
          <div class={`pkg-card ${i === 1 ? 'featured' : ''}`}>
            {i === 1 && <div class="featured-badge">Most Popular</div>}
            <h3>{pkg.title}</h3>
            <div class="pkg-price">{pkg.price}</div>
            <p>{pkg.description}</p>
            <a href="#book" class="btn-book">Book Now</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Booking -->
  <section class="booking" id="book">
    <div class="container">
      <h2>Book Your Session</h2>
      <p class="section-sub">All sessions are conducted online via video call.</p>
      <div class="cal-wrap">
        <iframe
          src={`https://cal.com/${CAL_USERNAME}`}
          frameborder="0"
          style="width:100%;height:100%">
        </iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <h2>FAQ</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>What platform do sessions happen on?</h3>
          <p>Video call (Zoom or Google Meet) while sharing a board on Lichess or Chess.com.</p>
        </div>
        <div class="faq-item">
          <h3>What skill level is this for?</h3>
          <p>All levels welcome. Sessions are tailored to where you are and where you want to go.</p>
        </div>
        <div class="faq-item">
          <h3>What should I bring?</h3>
          <p>Just yourself. A few recent games to review is a bonus but not required.</p>
        </div>
        <div class="faq-item">
          <h3>Can I reschedule?</h3>
          <p>Yes — reschedule or cancel directly through Cal.com up to 24 hours before your session.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 60px 0;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 14px;
  }

  .page-header p {
    color: #9095a0;
    font-size: 1rem;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Packages ── */
  .packages {
    padding: 72px 0;
  }

  h2 {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 40px;
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    align-items: start;
  }

  .pkg-card {
    background: #fff;
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 36px 28px;
    text-align: center;
    position: relative;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .pkg-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .pkg-card.featured {
    border-color: var(--accent);
    transform: scale(1.03);
  }

  .pkg-card.featured:hover {
    transform: scale(1.03) translateY(-2px);
  }

  .featured-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .pkg-card h3 {
    font-size: 1.2rem;
    margin-bottom: 10px;
  }

  .pkg-price {
    font-size: 2.6rem;
    font-weight: 700;
    font-family: var(--font-serif);
    color: var(--accent);
    margin-bottom: 14px;
  }

  .pkg-card p {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .btn-book {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    padding: 11px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.92rem;
    transition: background 0.18s, transform 0.1s;
  }

  .btn-book:hover {
    background: var(--accent-dark);
    transform: translateY(-1px);
  }

  /* ── Booking ── */
  .booking {
    background: #f0ede6;
    padding: 72px 0;
  }

  .section-sub {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: 36px;
    margin-top: -28px;
  }

  .cal-wrap {
    width: 100%;
    height: 700px;
    overflow: scroll;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: #fff;
  }

  /* ── FAQ ── */
  .faq {
    padding: 72px 0;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 820px;
    margin: 0 auto;
  }

  .faq-item {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 26px;
  }

  .faq-item h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .faq-item p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .packages-grid { grid-template-columns: 1fr; }
    .pkg-card.featured { transform: none; }
    .faq-grid { grid-template-columns: 1fr; }
  }
</style>
