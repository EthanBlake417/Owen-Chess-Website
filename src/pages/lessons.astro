---
import Layout from '../layouts/Layout.astro';
import lessonsData from '../content/lessons.json';

const CAL_USERNAME = 'ethan-blake-testing';
---

<Layout title="Lessons">

  <!-- Booking -->
  <section class="booking" id="book">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Coaching</p>
        <h1>Book your session</h1>
        <p>Conducted online via video call. Pick a slot that works for you.</p>
      </div>
      <div class="cal-wrap">
        <iframe
          src={`https://cal.com/${CAL_USERNAME}`}
          frameborder="0"
          style="width:100%;height:100%">
        </iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <div class="section-head">
        <h2>Questions</h2>
        <p>The most common things people ask before booking.</p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <h3>What platform do sessions happen on?</h3>
          <p>Video call (Zoom or Google Meet) while sharing a board on Lichess or Chess.com.</p>
        </div>
        <div class="faq-item">
          <h3>What skill level is this for?</h3>
          <p>All levels welcome. Sessions are tailored to where you are and where you want to go.</p>
        </div>
        <div class="faq-item">
          <h3>What should I bring?</h3>
          <p>Just yourself. A few recent games to review is a bonus but not required.</p>
        </div>
        <div class="faq-item">
          <h3>Can I reschedule?</h3>
          <p>Yes. Reschedule or cancel through Cal.com up to 24 hours before your session.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .section-head {
    margin-bottom: 36px;
    max-width: 600px;
  }

  .section-head h1 {
    font-size: clamp(2.2rem, 4.4vw, 3rem);
    margin-bottom: 14px;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .section-head h2 {
    font-size: 1.9rem;
    margin-bottom: 10px;
    letter-spacing: -0.005em;
  }

  .section-head p {
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.65;
  }

  /* ── Booking ── */
  .booking {
    background: var(--bg);
    padding: 64px 0 88px;
  }

  .cal-wrap {
    width: 100%;
    height: 700px;
    overflow: auto;
    background: var(--bg-card);
    border: 1px solid var(--border);
  }

  /* ── FAQ ── */
  .faq {
    padding: 88px 0;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 760px;
    border-top: 1px solid var(--border);
  }

  .faq-item {
    padding: 26px 4px;
    border-bottom: 1px solid var(--border);
  }

  .faq-item h3 {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }

  .faq-item p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>
